{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["* 0-6 * * *"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "labels": ["renovate"],
  "rebaseWhen": "behind-base-branch",
  "automerge": true,
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Warte 3 Tage bevor ein Update eingespielt wird",
      "matchPackagePatterns": ["*"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Major Updates: PR erstellen, aber kein Auto-Merge",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["renovate", "major update"]
    }
  ]
}