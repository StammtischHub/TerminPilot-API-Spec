{
  "name": "@stammtischhub/terminpilot-api-spec",
  "version": "0.0.0",
  "description": "OpenAPI Spec für TerminPilot",
  "main": "dist/openapi.bundled.yaml",
  "files": [
    "dist/"
  ],
  "scripts": {
    "version": "node scripts/sync-version.js",
    "build": "redocly bundle src/openapi.yaml -o dist/openapi.bundled.yaml",
    "validate": "redocly lint src/openapi.yaml",
    "prepublishOnly": "pnpm run validate && pnpm run build",
    "publish:ci:maven": "mvn deploy:deploy-file -Dfile=${OPENAPI_FILE} -DpomFile=${MAVEN_POM} -Durl=${MAVEN_PKG_URL} -DrepositoryId=${MAVEN_REPO_ID} -Dusername=${GITHUB_ACTOR} -Dpassword=${GITHUB_TOKEN}",
    "publish:ci:all:preview": "pnpm publish --no-git-checks --tag preview && pnpm run publish:ci:maven",
    "publish:ci:all:release": "pnpm publish --no-git-checks --tag latest && pnpm run publish:ci:maven"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@redocly/cli": "2.34.0",
    "js-yaml": "^4.2.0"
  }
}