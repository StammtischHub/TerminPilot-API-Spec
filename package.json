{
  "name": "@stammtischhub/terminpilot-api-spec",
  "version": "0.0.0",
  "description": "OpenAPI Spec für TerminPilot",
  "main": "dist/openapi.bundled.yaml",
  "files": [
    "dist/"
  ],
  "scripts": {
    "version": "node scripts/sync-version.js && git add src/openapi.yaml .github/deploy.xml",
    "build": "redocly bundle src/openapi.yaml -o dist/openapi.bundled.yaml",
    "validate": "redocly lint src/openapi.yaml",
    "prepublishOnly": "pnpm run validate && pnpm run build",
    "publish:maven": "mvn deploy:deploy-file -Dfile=dist/openapi.bundled.yaml -DpomFile=.github/deploy.xml -Dsettings=.github/maven-settings.xml",
    "publish:all:preview": "pnpm publish --no-git-checks --tag preview && pnpm run publish:maven",
    "publish:all:release": "pnpm publish --no-git-checks --tag latest && pnpm run publish:maven"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@redocly/cli": "2.34.0",
    "js-yaml": "^4.2.0"
  }
}