{
  "name": "@stammtischhub/terminpilot-api-spec",
  "version": "0.0.0",
  "description": "OpenAPI Spec für TerminPilot",
  "main": "dist/openapi.bundled.yaml",
  "files": [
    "dist/"
  ],
  "scripts": {
    "version": "node scripts/sync-version.js && git add src/openapi.yaml",
    "build": "redocly bundle src/openapi.yaml -o dist/openapi.bundled.yaml",
    "validate": "redocly lint src/openapi.yaml",
    "prepublishOnly": "npm run validate && npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@redocly/cli": "2.32.2",
    "js-yaml": "^4.2.0"
  }
}