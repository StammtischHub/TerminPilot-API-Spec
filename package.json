{
  "name": "@stammtischhub/terminpilot-api-spec",
  "version": "0.0.0",
  "description": "OpenAPI Spec für TerminPilot",
  "main": "dist/openapi.bundled.yaml",
  "files": [
    "dist/"
  ],
  "scripts": {
    "version": "node scripts/sync-version.js",
    "build": "redocly bundle src/openapi.yaml -o dist/openapi.bundled.yaml",
    "validate": "redocly lint src/openapi.yaml",
    "prepublishOnly": "pnpm run validate && pnpm run build",
    "publish:preview": "pnpm publish --no-git-checks --tag preview",
    "publish:release": "pnpm publish --no-git-checks --tag latest"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@redocly/cli": "2.34.0",
    "js-yaml": "^4.2.0"
  }
}